# ─── 360° Performance Review — Frontend Environment Variables ────────────────
# Copy this file to .env and fill in the values from your SAM deploy outputs.
#
# After running `sam deploy --guided`, retrieve values with:
#   aws cloudformation describe-stacks --stack-name <your-stack-name> \
#     --query "Stacks[0].Outputs" --output table
#
# ─────────────────────────────────────────────────────────────────────────────

# API Gateway endpoint (from SAM output: ApiEndpoint)
# Format: https://<api-id>.execute-api.<region>.amazonaws.com/<stage>
VITE_API_BASE=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/dev

# Cognito User Pool ID (from SAM output: UserPoolId)
# Format: <region>_<alphanumeric>
VITE_COGNITO_POOL_ID=us-east-1_XXXXXXXXX

# Cognito User Pool Client ID (from SAM output: UserPoolClientId)
# Format: 26-character alphanumeric string
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
